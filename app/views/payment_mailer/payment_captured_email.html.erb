<h2>Payment Confirmed</h2>
<p>Hi,</p>
<p>Your payment for order <strong><%= @payment.order_id %></strong> has been confirmed.</p>
<table style="border-collapse: collapse; width: 100%; max-width: 500px;">
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Order ID</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @payment.order_id %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Amount</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @payment.currency %> <%= @payment.amount / 100.0 %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Payment ID</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @payment.id %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Status</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd; color: green;"><strong>Captured</strong></td>
  </tr>
</table>
<p>Thank you for your payment.</p>
