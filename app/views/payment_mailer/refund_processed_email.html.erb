<h2>Refund Processed</h2>
<p>Hi,</p>
<p>Your refund for order <strong><%= @payment.order_id %></strong> has been processed.</p>
<table style="border-collapse: collapse; width: 100%; max-width: 500px;">
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Order ID</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @payment.order_id %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Refund Amount</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @payment.currency %> <%= @refund_amount / 100.0 %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd;"><strong>Status</strong></td>
    <td style="padding: 8px; border: 1px solid #ddd; color: blue;"><strong>Refunded</strong></td>
  </tr>
</table>
<p>The amount will reflect in your account within 5-7 business days.</p>
